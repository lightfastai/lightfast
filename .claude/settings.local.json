{
  "permissions": {
    "allow": [
      "Bash(pnpm add:*)",
      "Bash(node:*)"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "disableAllHooks": false,
  "outputStyle": "Explanatory",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  },
  "prefersReducedMotion": true
}
