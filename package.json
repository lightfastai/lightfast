{
  "name": "lightfast",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "build:app": "turbo run build -F @lightfast/app",
    "build:www": "turbo run build -F @lightfast/www",
    "build:platform": "turbo run build -F @lightfast/platform",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "node scripts/dev-services.mjs inngest-sync --mfe-app lightfast-app -- lightfast-dev proxy turbo --local-app lightfast-www --local-app lightfast-app run dev --concurrency=15 -F @lightfast/www -F @lightfast/app --continue",
    "dev:app": "node scripts/dev-services.mjs inngest-sync --mfe-app lightfast-app -- lightfast-dev proxy turbo run dev -F @lightfast/app",
    "dev:www": "lightfast-dev proxy turbo run dev -F @lightfast/www",
    "dev:platform": "node scripts/dev-services.mjs inngest-sync --app-url lightfast-platform=http://localhost:4112 -- turbo run dev -F @lightfast/platform --continue",
    "dev:full": "node scripts/dev-services.mjs inngest-sync --mfe-app lightfast-app --app-url lightfast-platform=http://localhost:4112 -- lightfast-dev proxy turbo --local-app lightfast-www --local-app lightfast-app run dev --concurrency=15 -F @lightfast/www -F @lightfast/app -F @lightfast/platform --continue",
    "dev:desktop": "pnpm --filter @lightfast/desktop dev",
    "dev:log": "NO_COLOR=1 pnpm dev 2>&1 | tee /tmp/lightfast-dev.log",
    "dev:inngest": "npx inngest-cli@latest dev",
    "dev:services": "concurrently -n inngest,studio -c blue,green \"pnpm dev:inngest\" \"pnpm dev:studio\"",
    "dev:studio": "pnpm --filter @db/app with-env drizzle-kit studio --config=./src/drizzle.config.ts --host 127.0.0.1 --port 4983",
    "dev:setup": "node scripts/dev-services.mjs setup && pnpm db:migrate",
    "dev:doctor": "node scripts/dev-services.mjs doctor --postgres-table lightfast_gateway_installations",
    "dev:ngrok": "./scripts/ngrok 3024",
    "dev:email": "turbo run dev:email -F @lightfast/www",
    "brain": "turbo run eval",
    "check": "npx ultracite@latest check",
    "fix": "npx ultracite@latest fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "test": "SKIP_ENV_VALIDATION=true turbo run test",
    "typecheck": "SKIP_ENV_VALIDATION=true turbo run typecheck",
    "ui": "pnpm --filter @repo/ui ui",
    "vercel:link": "vercel link --repo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "claude": "./scripts/c",
    "remotion:studio": "pnpm --filter @repo/app-remotion studio",
    "remotion:render": "pnpm --filter @repo/app-remotion render:all",
    "db:url": "node scripts/dev-services.mjs postgres url",
    "db:up": "node scripts/dev-services.mjs postgres up",
    "db:create": "node scripts/dev-services.mjs postgres create",
    "db:generate": "pnpm --filter @db/app db:generate",
    "db:migrate": "pnpm --filter @db/app db:migrate",
    "redis:url": "node scripts/dev-services.mjs redis url",
    "redis:up": "node scripts/dev-services.mjs redis up",
    "redis:ping": "node scripts/dev-services.mjs redis ping",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.31.0",
    "@lightfastai/dev-cli": "catalog:",
    "@lightfastai/dev-core": "catalog:",
    "@lightfastai/dev-proxy": "catalog:",
    "@lightfastai/dev-services": "catalog:",
    "concurrently": "^9.2.1",
    "knip": "^6.4.1",
    "portless": "catalog:",
    "turbo": "2.9.6",
    "turbo-ignore": "2.9.6",
    "typescript": "^5.9.2",
    "ultracite": "7.6.0",
    "vercel": "^51.7.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@opentelemetry/api": "1.9.1",
      "tar": "^7.5.13",
      "basic-ftp": "^5.3.0",
      "undici": "^6.25.0",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "path-to-regexp": "^6.3.0",
      "fast-xml-parser": "^5.5.6"
    }
  }
}
