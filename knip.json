{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{js,ts,sh}"],
      "ignoreDependencies": ["turbo-ignore"]
    },
    "apps/console": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts", "sentry.*.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/www": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts", "sentry.*.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/auth": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts", "sentry.*.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/docs": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/relay": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/gateway": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["drizzle-orm"]
    },
    "apps/backfill": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "api/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "core/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "db/*": {
      "entry": ["src/index.ts", "src/drizzle.config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/og": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["react"]
    },
    "vendor/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "drizzle": false
    },
    "vendor/cms": {
      "entry": ["src/index.ts", "lib/**/*.ts", "components/**/*.tsx"],
      "project": ["src/**/*.ts", "lib/**/*.ts", "components/**/*.tsx"],
      "drizzle": false
    },
    "vendor/inngest": {
      "entry": ["src/index.ts", "env.ts"],
      "project": ["src/**/*.ts", "env.ts"],
      "drizzle": false
    },
    "vendor/upstash-workflow": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "drizzle": false,
      "ignoreDependencies": ["next"]
    },
    "internal/eslint": {
      "entry": ["base.js", "nextjs.js", "react.js", "hono.js"]
    },
    "internal/prettier": {
      "entry": ["index.js"]
    },
    "internal/typescript": {
      "entry": ["base.json"]
    }
  },
  "ignore": [
    "tmp/**",
    "worktrees/**",
    "thoughts/**",
    ".agents/**",
    ".claude/**",
    "**/drizzle.config.ts",
    "**/sentry.*.config.ts",
    "**/sentry-init.ts"
  ],
  "ignoreWorkspaces": [
    "packages/console-remotion",
    "packages/tech-stack-detector"
  ],
  "ignoreDependencies": [
    "@repo/typescript-config",
    "@repo/prettier-config",
    "@repo/eslint-config",
    "@repo/console-remotion",
    "@repo/tech-stack-detector",
    "tailwindcss",
    "@tailwindcss/postcss",
    "@tailwindcss/typography",
    "postcss",
    "autoprefixer",
    "import-in-the-middle",
    "require-in-the-middle",
    "srvx",
    "tsx",
    "prettier",
    "eslint"
  ]
}
