{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{js,ts,sh}"],
      "ignoreDependencies": ["turbo-ignore", "@biomejs/biome"]
    },
    "apps/console": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@repo/console-auth-middleware",
        "@repo/lib",
        "@vitest/expect",
        "zustand"
      ]
    },
    "apps/www": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["jiti"]
    },
    "apps/docs": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "api/*": {
      "project": ["src/**/*.ts"]
    },
    "core/*": {
      "project": ["src/**/*.ts"]
    },
    "core/ai-sdk": {
      "entry": ["src/core/memory/adapters/*.ts", "src/core/test-utils/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "db/*": {
      "entry": ["src/drizzle.config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/cms-workflows": {
      "entry": ["src/publish-blog.ts", "src/publish-changelog.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/console-ai": {
      "entry": ["src/workspace-*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/console-test-data": {
      "entry": ["src/cli/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/console-trpc": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/console-vercel": {
      "project": ["src/**/*.ts"]
    },
    "packages/og": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["react", "@types/react"]
    },
    "packages/console-upstash-realtime": {
      "ignoreDependencies": ["@types/react"]
    },
    "packages/ui": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@turbo/gen"]
    },
    "vendor/*": {
      "project": ["src/**/*.ts"],
      "drizzle": false
    },
    "vendor/analytics": {
      "project": ["src/**/*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/cms": {
      "entry": ["lib/**/*.ts", "components/**/*.tsx"],
      "project": ["lib/**/*.ts", "components/**/*.tsx", "*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/seo": {
      "project": ["*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/inngest": {
      "drizzle": false
    },
    "vendor/next": {
      "project": ["src/**/*.ts"],
      "drizzle": false,
      "ignoreDependencies": ["webpack"]
    },
    "internal/typescript": {
      "entry": ["base.json"],
      "ignoreDependencies": ["hono", "next"]
    }
  },
  "ignore": [
    ".agents/**",
    ".claude/**",
    "apps/console/src/lib/base-url.ts",
    "apps/www/src/lib/base-url.ts"
  ],
  "ignoreWorkspaces": ["packages/console-remotion"],
  "ignoreDependencies": [
    "tailwindcss",
    "@tailwindcss/postcss",
    "@tailwindcss/typography",
    "postcss",
    "autoprefixer",
    "import-in-the-middle",
    "require-in-the-middle",
    "tsx",
    "@vitest/coverage-v8"
  ]
}
