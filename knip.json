{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{js,ts,sh,mjs}"],
      "ignoreDependencies": ["turbo-ignore", "@biomejs/biome", "portless"]
    },
    "apps/app": {
      "entry": [
        "src/{client,server,start}.{ts,tsx}",
        "src/app/**/*.{ts,tsx}",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}",
        "src/__tests__/setup-env.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@vendor/lib", "@vitest/expect", "zustand"]
    },
    "apps/mcp": {
      "entry": [
        "instrument.server.mjs",
        "src/{client,server,start}.{ts,tsx}",
        "src/routes/**/*.{ts,tsx}",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}",
        "src/__tests__/setup-env.ts"
      ],
      "project": ["instrument.server.mjs", "src/**/*.{ts,tsx}"]
    },
    "apps/www": {
      "entry": [
        "src/{client,server,start}.{ts,tsx}",
        "src/app/**/*.{ts,tsx}",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["jiti"]
    },
    "api/app": {
      "entry": [
        "src/origins.ts",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}",
        "src/__tests__/setup-env.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "apps/desktop": {
      "entry": [
        "src/main/bootstrap.ts",
        "src/main/index.ts",
        "src/preload/**/*.ts",
        "src/renderer/src/main.ts",
        "src/renderer/src/react/**/*.{ts,tsx}",
        "forge.config.ts",
        "vite.main.config.ts",
        "vite.preload.config.ts",
        "vite.renderer.config.ts",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}",
        "scripts/**/*.mjs"
      ],
      "project": ["src/**/*.{ts,tsx}", "vite.*.config.ts", "scripts/**/*.mjs"],
      "ignoreDependencies": ["@sentry/electron", "@sentry/cli", "superjson"]
    },
    "apps/remotion": {
      "entry": [
        "src/index.ts",
        "src/render.ts",
        "src/watch.ts",
        "src/__tests__/**/*.{test,spec}.{ts,tsx}",
        "remotion.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "remotion.config.ts"]
    },
    "core/*": {
      "project": ["src/**/*.ts"]
    },
    "connectors/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "connectors/*": {
      "entry": ["src/{contract,mcp,node,oauth,operations,tools}.ts"],
      "project": ["src/**/*.ts"]
    },
    "core/mcp": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@modelcontextprotocol/sdk"]
    },
    "db/*": {
      "entry": ["src/drizzle.config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@turbo/gen"]
    },
    "vendor/*": {
      "project": ["src/**/*.ts"],
      "drizzle": false
    },
    "vendor/aeo": {
      "project": ["*.ts"],
      "drizzle": false
    },
    "vendor/analytics": {
      "project": ["src/**/*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/seo": {
      "project": ["src/**/*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/inngest": {
      "drizzle": false
    },
    "vendor/next": {
      "project": ["src/**/*.ts"],
      "drizzle": false
    },
    "internal/typescript": {
      "entry": ["base.json"],
      "ignoreDependencies": ["next"]
    },
    "internal/vitest-config": {}
  },
  "ignore": [".agents/**", ".claude/**"],
  "ignoreDependencies": [
    "tailwindcss",
    "@tailwindcss/postcss",
    "@tailwindcss/typography",
    "postcss",
    "autoprefixer",
    "import-in-the-middle",
    "require-in-the-middle"
  ]
}
