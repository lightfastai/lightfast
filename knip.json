{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{js,ts,sh}"],
      "ignoreDependencies": ["turbo-ignore"]
    },
    "apps/console": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "next.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/www": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "next.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/auth": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "next.config.ts",
        "playwright.config.ts",
        "e2e/**/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts"]
    },
    "apps/docs": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/relay": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/gateway": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["drizzle-orm"]
    },
    "apps/backfill": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "api/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "core/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "db/*": {
      "entry": ["src/index.ts", "src/drizzle.config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/cms-workflows": {
      "entry": [
        "src/index.ts",
        "src/publish-blog.ts",
        "src/publish-changelog.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/console-test-data": {
      "entry": ["src/index.ts", "src/cli/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/integration-tests": {
      "entry": ["src/**/*.test.ts", "src/**/*.integration.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@repo/console-backfill",
        "@repo/lib",
        "@relay/webhook-delivery",
        "@vendor/inngest",
        "@vendor/qstash",
        "@vendor/related-projects",
        "@vendor/upstash",
        "@vendor/upstash-workflow"
      ]
    },
    "packages/og": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["react", "@types/react"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@turbo/gen"]
    },
    "vendor/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "drizzle": false
    },
    "vendor/cms": {
      "entry": ["lib/**/*.ts", "components/**/*.tsx"],
      "project": ["lib/**/*.ts", "components/**/*.tsx", "*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/seo": {
      "project": ["*.{ts,tsx}"],
      "drizzle": false
    },
    "vendor/inngest": {
      "entry": ["src/index.ts", "env.ts"],
      "project": ["src/**/*.ts", "env.ts"],
      "drizzle": false
    },
    "vendor/upstash-workflow": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "drizzle": false,
      "ignoreDependencies": ["next"]
    },
    "vendor/next": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "drizzle": false,
      "ignoreDependencies": ["webpack"]
    },
    "internal/typescript": {
      "entry": ["base.json"],
      "ignoreDependencies": ["hono", "next"]
    }
  },
  "ignore": [
    "tmp/**",
    "worktrees/**",
    "thoughts/**",
    ".agents/**",
    ".claude/**"
  ],
  "ignoreWorkspaces": ["packages/console-remotion"],
  "ignoreDependencies": [
    "@repo/typescript-config",
    "tailwindcss",
    "@tailwindcss/postcss",
    "@tailwindcss/typography",
    "postcss",
    "autoprefixer",
    "import-in-the-middle",
    "require-in-the-middle",
    "srvx",
    "tsx",
    "@vitest/coverage-v8"
  ]
}
