{
  "name": "@db/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./utils": {
      "types": "./src/utils/org.ts",
      "default": "./src/utils/org.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./migrations": "./src/migrations/meta/_journal.json"
  },
  "license": "Apache-2.0",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "dev:studio": "pnpm db:studio",
    "db:push": "pnpm with-env drizzle-kit push --config=./src/drizzle.config.ts",
    "db:generate": "SKIP_ENV_VALIDATION=1 drizzle-kit generate --config=./src/drizzle.config.ts",
    "db:migrate": "tsx ./src/migrate.ts",
    "db:baseline": "tsx ./src/baseline.ts",
    "db:studio": "pnpm with-env drizzle-kit studio --config=./src/drizzle.config.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../apps/app/.vercel/.env.development.local -- node ../../scripts/with-dev-services-env.mjs --"
  },
  "dependencies": {
    "@repo/api-contract": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@vendor/db": "workspace:*",
    "@vendor/lib": "workspace:*",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@planetscale/database": "^1.20.1",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
