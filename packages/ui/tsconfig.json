{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/compiled-package.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "emitDeclarationOnly": false,
    "baseUrl": ".",
    "paths": {
      "@repo/ui/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
