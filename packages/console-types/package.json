{
  "name": "@repo/console-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./api": "./src/api/index.ts",
    "./api/search": "./src/api/search.ts",
    "./api/common": "./src/api/common.ts",
    "./api/contents": "./src/api/contents.ts",
    "./api/v1/search": "./src/api/v1/search.ts",
    "./api/v1/contents": "./src/api/v1/contents.ts",
    "./api/v1/findsimilar": "./src/api/v1/findsimilar.ts",
    "./api/v1/graph": "./src/api/v1/graph.ts",
    "./workspace": "./src/workspace.ts",
    "./entity": "./src/entity.ts"
  },
  "license": "FSL-1.1-Apache-2.0",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/console-validation": "workspace:*",
    "zod": "catalog:zod4"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@repo/prettier-config"
}
