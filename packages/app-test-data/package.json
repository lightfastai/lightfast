{
  "name": "@repo/app-test-data",
  "license": "Apache-2.0",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./trigger": {
      "types": "./src/trigger/index.ts",
      "default": "./src/trigger/index.ts"
    },
    "./loader": {
      "types": "./src/loader/index.ts",
      "default": "./src/loader/index.ts"
    },
    "./raw": {
      "types": "./src/raw.ts",
      "default": "./src/raw.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../apps/app/.vercel/.env.development.local --",
    "inject": "pnpm with-env tsx src/cli/inject.ts",
    "inject:prod": "dotenv -e ../../apps/app/.vercel/.env.production.local -- tsx src/cli/inject.ts",
    "seed-integrations:prod": "dotenv -e ../../apps/app/.vercel/.env.production.local -- tsx src/cli/seed-integrations.ts",
    "reset-demo": "pnpm with-env tsx src/cli/reset-demo.ts",
    "verify": "tsx src/cli/generate-schema.ts && tsx src/cli/verify-datasets.ts",
    "generate-schema": "tsx src/cli/generate-schema.ts",
    "clean": "git clean -xdf .cache .turbo node_modules"
  },
  "dependencies": {
    "@api/platform": "workspace:*",
    "@db/app": "workspace:*",
    "@repo/app-providers": "workspace:*",
    "@vendor/db": "workspace:*",
    "@vendor/lib": "workspace:*",
    "@vendor/observability": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
