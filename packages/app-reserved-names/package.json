{
  "name": "@repo/app-reserved-names",
  "version": "0.1.0",
  "private": true,
  "description": "Reserved organization names for Lightfast App to prevent URL routing conflicts",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./organization": {
      "types": "./src/organization.ts",
      "default": "./src/organization.ts"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "lightfast",
    "reserved",
    "organization",
    "validation"
  ],
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
