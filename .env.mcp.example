# MCP Server Environment Variables
# Copy this file to .env.mcp and fill in your actual values
# .env.mcp is gitignored and will not be committed

# Lightfast API Key
# Get from: https://lightfast.ai (Settings > API Keys)
LIGHTFAST_API_KEY=

# Exa API Key
# Get from: https://dashboard.exa.ai/api-keys
EXA_API_KEY=
