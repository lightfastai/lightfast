{
  "name": "@api/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./inngest": {
      "types": "./src/inngest/index.ts",
      "default": "./src/inngest/index.ts"
    },
    "./inngest/client": {
      "types": "./src/inngest/client/client.ts",
      "default": "./src/inngest/client/client.ts"
    },
    "./lib/activity": {
      "types": "./src/lib/activity.ts",
