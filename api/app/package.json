    },
    "./lib/token-vault": {
      "types": "./src/lib/token-vault.ts",
      "default": "./src/lib/token-vault.ts"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
