    "@trpc/server": "catalog:",
    "@vendor/clerk": "workspace:*",
    "@vendor/inngest": "workspace:*",
    "@vendor/observability": "workspace:*",
    "drizzle-orm": "catalog:",
    "inngest": "catalog:",
    "superjson": "catalog:",
    "yaml": "^2.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
