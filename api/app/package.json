    "@vendor/clerk": "workspace:*",
    "@vendor/inngest": "workspace:*",
    "@vendor/observability": "workspace:*",
    "@vercel/related-projects": "catalog:",
    "drizzle-orm": "catalog:",
    "inngest": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
