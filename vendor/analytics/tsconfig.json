{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "paths": {
      "~/env": [
        "./env.ts"
      ]
    }
  },
  "include": [
    "*.ts",
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}
