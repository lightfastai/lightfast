{
  "name": "@vendor/cms",
  "license": "MIT",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./next-config": {
      "types": "./src/next-config.ts",
      "default": "./src/next-config.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    }
  },
  "scripts": {
    "dev": "basehub dev",
    "build": "echo '[skip] @vendor/cms build is handled by the consuming app'",
    "basehub:build": "basehub build",
    "analyze": "basehub",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "catalog:",
    "basehub": "^9.5.3",
    "clsx": "catalog:",
    "react": "19.2.4",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:next16",
    "typescript": "catalog:"
  }
}
