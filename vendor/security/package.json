{
  "name": "@vendor/security",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./env": "./env.ts",
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "default": "./dist/src/middleware.js"
    },
    "./clerk-nosecone": {
      "types": "./dist/src/clerk-nosecone.d.ts",
