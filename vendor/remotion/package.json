{
  "name": "@vendor/remotion",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./renderer": {
      "types": "./dist/src/renderer.d.ts",
      "default": "./src/renderer.ts"
    },
    "./bundler": {
      "types": "./dist/src/bundler.d.ts",
      "default": "./src/bundler.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.434",
    "@remotion/renderer": "^4.0.434",
    "remotion": "^4.0.434"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
