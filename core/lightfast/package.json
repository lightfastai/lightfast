{
  "name": "lightfast",
  "version": "0.1.0-alpha.5",
  "description": "Lightfast Platform SDK - TypeScript client for the Lightfast Platform API",
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  },
  "keywords": [
    "lightfast",
    "platform",
    "ai",
    "semantic-search",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lightfastai/lightfast.git",
    "directory": "core/lightfast"
  },
  "homepage": "https://lightfast.ai",
  "bugs": "https://github.com/lightfastai/lightfast/issues",
  "license": "MIT",
  "author": "Lightfast <hello@lightfast.ai>",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist .cache .turbo node_modules",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@orpc/client": "^1.13.14",
    "@orpc/contract": "^1.13.14",
    "@orpc/openapi-client": "^1.13.14",
    "@repo/app-api-contract": "workspace:*",
    "@repo/app-validation": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
