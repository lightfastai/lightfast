{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".cache/tsbuildinfo.json",
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**"
      ],
      "env": ["NEXT_PUBLIC_*", "SENTRY_*", "VERCEL_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:inngest": {
      "cache": false,
      "persistent": true
    },
    "dev:ngrok": {
      "cache": false,
      "persistent": true
    },
    "//#dev:ngrok": {
      "cache": false,
      "persistent": true
    },
    "dev:studio": {
      "cache": false,
      "persistent": true
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts", "tsconfig.json"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "transit"],
      "outputs": [".cache/tsbuildinfo.json"],
      "env": []
    },
    "clean": {
      "cache": false
    },
    "migrate": {
      "cache": false
    },
    "migrate:generate": {
      "cache": false
    },
    "generate:openapi": {
      "dependsOn": ["^build"],
      "outputs": ["openapi.json"]
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "dev:email": {
      "cache": false,
      "persistent": true
    },
    "ui": {
      "cache": false,
      "interactive": true
    },
    "eval": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": ["CI"],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "SKIP_ENV_VALIDATION",
    "npm_lifecycle_event",
    "VERCEL",
    "VERCEL_URL",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "BETTERSTACK_SOURCE_TOKEN"
  ],
  "boundaries": {
    "implicitDependencies": ["~"],
    "tags": {
      "vendor": {
        "dependencies": { "deny": ["packages", "data", "api", "app"] }
      },
      "internal": {
        "dependencies": {
          "deny": ["vendor", "packages", "data", "api", "app", "core"]
        }
      },
      "app": {
        "dependents": {
          "deny": ["vendor", "packages", "data", "api", "core", "internal"]
        }
      }
    }
  }
}
