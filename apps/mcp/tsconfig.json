{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "types": ["node"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [".", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
