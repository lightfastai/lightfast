{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "APP_INTERNAL_URL",
        "MCP_AUTH_ISSUER",
        "MCP_RESOURCE_URL",
        "SERVICE_JWT_SECRET",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "VITE_SENTRY_DSN",
        "VITE_*",
        "VERCEL_ENV"
      ],
      "passThroughEnv": ["HOST", "PORT"],
      "inputs": ["$TURBO_DEFAULT$", ".vercel/.env*"],
      "outputs": [
        ".output/**",
        ".vercel/output/**",
        "dist/**",
        "src/routeTree.gen.ts"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["HOST", "PORT", "PORTLESS_URL"]
    },
    "transit": {}
  }
}
