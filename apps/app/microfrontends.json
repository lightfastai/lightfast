{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "lightfast-app": {
      "packageName": "@lightfast/app",
      "development": {
        "fallback": "https://lightfast.ai"
      }
    },
    "lightfast-www": {
      "packageName": "@lightfast/www",
      "development": {
        "fallback": "https://lightfast.ai"
      },
      "routing": [
        {
          "group": "marketing",
          "paths": [
            "/",
            "/v2/:path*",
            "/opengraph-image-:hash",
            "/pricing",
            "/brand",
            "/blog",
            "/blog/:path*",
            "/use-cases/:path*",
            "/search",
            "/pitch-deck",
            "/company",
            "/company/:path*",
            "/careers",
            "/careers/:path",
            "/api/health",
            "/images/:path*",
            "/fonts/:path*",
            "/favicon.ico",
            "/favicon-16x16.png",
            "/favicon-32x32.png",
            "/favicon-48x48.png",
            "/android-chrome-192x192.png",
            "/android-chrome-512x512.png",
            "/apple-touch-icon.png",
            "/docs",
            "/docs/:path*",
            "/sitemap.xml",
            "/robots.txt",
            "/manifest.webmanifest",
            "/manifest.json",
            "/llms.txt"
          ]
        }
      ]
    }
  }
}
