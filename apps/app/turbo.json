{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BRAINTRUST_API_KEY",
        "CLERK_SECRET_KEY",
        "HEALTH_CHECK_AUTH_TOKEN",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_VERCEL_ENV",
        "NEXT_PUBLIC_WWW_URL",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SERVICE_JWT_SECRET",
        "VERCEL_ENV",
        "VITE_*"
      ],
      "passThroughEnv": [
        "CLERK_CLI_OAUTH_CLIENT_ID",
        "CLERK_DESKTOP_OAUTH_CLIENT_ID",
        "CONNECTOR_MCP_AUTH_SECRET",
        "DATABASE_HOST",
        "DATABASE_USERNAME",
        "DATABASE_PASSWORD",
        "DEVELOPER_AUTH_BOX_ORIGIN",
        "DEVELOPER_AUTH_BOX_TOKEN",
        "ENCRYPTION_KEY",
        "GITHUB_API_VERSION",
        "GITHUB_APP_CLIENT_ID",
        "GITHUB_APP_CLIENT_SECRET",
        "GITHUB_APP_ENDPOINT_ORIGIN",
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY",
        "GITHUB_APP_SLUG",
        "GITHUB_APP_WEBHOOK_SECRET",
        "HOST",
        "INNGEST_APP_NAME",
        "INNGEST_EVENT_KEY",
        "INNGEST_SERVE_ORIGIN",
        "INNGEST_SIGNING_KEY",
        "KV_REST_API_TOKEN",
        "KV_REST_API_URL",
        "LINEAR_API_ORIGIN",
        "LINEAR_CLIENT_ID",
        "LINEAR_CLIENT_SECRET",
        "LINEAR_MCP_ENDPOINT",
        "PORT",
        "PORTLESS_URL",
        "UNKEY_API_ID",
        "UNKEY_ROOT_KEY",
        "X_CLIENT_ID",
        "X_CLIENT_SECRET"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env.overrides.local", ".vercel/.env*"],
      "outputs": [".output/**", "dist/**", "src/routeTree.gen.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["HOST", "PORT", "PORTLESS_URL"]
    },
    "mfe:proxy": {
      "cache": false,
      "persistent": true
    },
    "transit": {}
  }
}
