{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN",
        "NEXT_PUBLIC_BETTER_STACK_INGESTING_URL",
        "NEXT_PUBLIC_VERCEL_ENV",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_WWW_URL",
        "NEXT_PUBLIC_PLATFORM_URL",
        "VERCEL_ENV"
      ],
      "passThroughEnv": [
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "BRAINTRUST_API_KEY",
        "CLERK_SECRET_KEY",
        "CLERK_CLI_OAUTH_CLIENT_ID",
        "CLERK_DESKTOP_OAUTH_CLIENT_ID",
        "DATABASE_HOST",
        "DATABASE_PORT",
        "DATABASE_USERNAME",
        "DATABASE_PASSWORD",
        "DATABASE_NAME",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "HEALTH_CHECK_AUTH_TOKEN",
        "ARCJET_KEY",
        "INNGEST_APP_NAME",
        "INNGEST_EVENT_KEY",
        "INNGEST_SERVE_HOST",
        "INNGEST_SIGNING_KEY",
        "UNKEY_API_ID",
        "UNKEY_ROOT_KEY",
        "SERVICE_JWT_SECRET",
        "PORT"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".vercel/.env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "next-env.d.ts"
      ]
    },
    "dev": {
      "persistent": true,
      "with": ["//#dev:ngrok"]
    },
    "mfe:proxy": {
      "cache": false,
      "persistent": true
    },
    "transit": {}
  }
}
