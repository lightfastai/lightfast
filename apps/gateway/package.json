{
  "name": "@lightfast/gateway",
  "license": "FSL-1.1-Apache-2.0",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && tsup && pnpm with-env node dist/src/env.js",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "NODE_ENV=development pnpm with-env srvx --prod --import tsx -p 4110 src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ./.vercel/.env.development.local --"
  },
  "dependencies": {
    "@db/console": "workspace:*",
    "@repo/console-providers": "workspace:*",
    "@repo/console-validation": "workspace:*",
    "@repo/gateway-service-clients": "workspace:*",
    "@repo/lib": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@vendor/db": "workspace:*",
    "@vendor/observability": "workspace:*",
    "@vendor/qstash": "workspace:*",
    "@vendor/related-projects": "workspace:*",
    "@vendor/upstash": "workspace:*",
    "@vendor/upstash-workflow": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:zod4"
  },
  "devDependencies": {
    "@repo/console-test-db": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "srvx": "^0.11.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
