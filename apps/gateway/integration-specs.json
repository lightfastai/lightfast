{
  "$comment": "Integration creation specs. Reference for configuring provider apps/integrations across environments.",
  "github": {
    "$comment": "GitHub App — https://github.com/settings/apps",
    "app": {
      "name": "lightfastai-dev",
      "description": "Lightfast connects your GitHub repositories for AI-powered code intelligence.",
      "public_link": "https://github.com/apps/lightfastai-dev",
      "homepage_url": "https://lightfast.ai",
      "public": true
    },
    "oauth": {
      "callback_urls": [
        "http://localhost:3024/services/gateway/github/callback"
      ],
      "request_oauth_on_install": false,
      "enable_device_flow": false
    },
    "post_installation": {
      "setup_url": "http://localhost:3024/services/gateway/github/callback",
      "redirect_on_update": false
    },
    "webhooks": {
      "active": true,
      "$comment_url": "Webhooks must go DIRECTLY to the relay — not through the console proxy (lightfast.ai/services/relay/...). The Next.js proxy re-streams the body, breaking GitHub's HMAC signature. Dev: run ngrok on port 4108 and use /api/webhooks/github. Prod: use the relay Vercel URL directly.",
      "url_dev": "https://<ngrok-subdomain>.ngrok-free.dev/api/webhooks/github",
      "url_prod": "https://lightfast-relay.vercel.app/api/webhooks/github",
      "events": [
        "installation",
        "meta",
        "pull_request",
        "issues"
      ]
    },
    "permissions": {
      "repository": {
        "contents": "read",
        "issues": "read",
        "metadata": "read",
        "pull_requests": "read"
      },
      "organization": {
        "members": "read"
      },
      "account": {}
    },
    "env_keys": [
      "GITHUB_APP_ID",
      "GITHUB_APP_PRIVATE_KEY",
      "GITHUB_APP_SLUG",
      "GITHUB_CLIENT_ID",
      "GITHUB_CLIENT_SECRET",
      "GITHUB_WEBHOOK_SECRET"
    ]
  },

  "vercel": {
    "$comment": "Vercel Integration — https://vercel.com/dashboard/integrations/console",
    "integration": {
      "name": "Lightfast",
      "url_slug": "lightfast-dev",
      "developer": "Lightfast AI",
      "category": "Dev Tools",
      "short_description": "AI-powered deployment intelligence.",
      "website": "https://lightfast.ai",
      "documentation_url": "https://lightfast.ai/docs",
      "support_url": "https://lightfast.ai/support"
    },
    "oauth": {
      "redirect_url": "http://localhost:3024/services/gateway/vercel/callback",
      "configuration_url": "http://localhost:3024/settings/integrations/vercel"
    },
    "webhooks": {
      "url_dev": "https://<ngrok-subdomain>.ngrok-free.dev/api/webhooks/vercel",
      "url_prod": "https://lightfast-relay.vercel.app/api/webhooks/vercel",
      "events": [
        "deployment.created",
        "deployment.succeeded",
        "deployment.ready",
        "deployment.error",
        "deployment.canceled",
        "deployment.integration.action.start",
        "deployment.integration.action.cancel",
        "deployment.integration.action.cleanup",
        "integration-configuration.removed",
        "marketplace.invoice.created",
        "marketplace.invoice.paid",
        "marketplace.invoice.notpaid",
        "marketplace.invoice.refunded"
      ]
    },
    "scopes": {
      "integration-configuration": "read",
      "deployment": "read",
      "project": "read",
      "project-env-vars": "none",
      "team": "read",
      "user": "read"
    },
    "env_keys": [
      "VERCEL_INTEGRATION_SLUG",
      "VERCEL_CLIENT_SECRET_ID",
      "VERCEL_CLIENT_INTEGRATION_SECRET",
      "VERCEL_REDIRECT_URI"
    ]
  },

  "linear": {
    "$comment": "Linear OAuth App — https://linear.app/settings/api/applications",
    "application_name": "Lightfast",
    "developer_name": "Lightfast AI",
    "developer_url": "https://lightfast.ai",
    "description": "Lightfast connects your Linear workspace for AI-powered project intelligence.",
    "callback_urls": ["http://localhost:3024/services/gateway/linear/callback"],
    "public": true,
    "client_credentials": "$comment: Copy CLIENT_ID and CLIENT_SECRET after creation (secret shown only once)",
    "webhooks": {
      "enabled": true,
      "url_dev": "https://<ngrok-subdomain>.ngrok-free.dev/api/webhooks/linear",
      "url_prod": "https://lightfast-relay.vercel.app/api/webhooks/linear",
      "resource_types": ["Issue", "Comment", "IssueLabel", "Project", "Cycle"]
    },
    "env_keys": [
      "LINEAR_CLIENT_ID",
      "LINEAR_CLIENT_SECRET",
      "LINEAR_WEBHOOK_SIGNING_SECRET"
    ]
  },

  "sentry": {
    "$comment": "Sentry Public Integration — https://sentry.io/settings/<org>/developer-settings/",
    "integration": {
      "name": "Lightfast",
      "author": "Lightfast AI",
      "overview": "Lightfast connects your Sentry projects for AI-powered error intelligence and observability.",
      "verify_installation": false,
      "alert_rule_action": false,
      "schema": {}
    },
    "oauth": {
      "redirect_url": "http://localhost:3024/services/gateway/sentry/callback",
      "authorized_javascript_origins": []
    },
    "webhooks": {
      "url_dev": "https://<ngrok-subdomain>.ngrok-free.dev/api/webhooks/sentry",
      "url_prod": "https://lightfast-relay.vercel.app/api/webhooks/sentry",
      "resources": ["issue", "event_alert", "seer", "comment"]
    },
    "permissions": {
      "project": "read",
      "team": "no-access",
      "release": "no-access",
      "distribution": "no-access",
      "issue-and-event": "read",
      "organization": "read",
      "member": "no-access",
      "alerts": "read"
    },
    "env_keys": ["SENTRY_APP_SLUG", "SENTRY_CLIENT_ID", "SENTRY_CLIENT_SECRET"]
  }
}
