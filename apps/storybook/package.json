{
  "name": "@lightfast/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "portless": "storybook.lightfast",
  "scripts": {
    "dev": "portless run pnpm storybook:dev",
    "storybook:dev": "storybook dev --host ${HOST:-127.0.0.1} --port ${PORT:-6006} --no-open",
    "build": "storybook build",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo storybook-static node_modules"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "catalog:",
    "@hugeicons/react": "catalog:",
    "@repo/ui-v2": "workspace:*",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:tailwind4",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "msw": "catalog:",
    "msw-storybook-addon": "catalog:",
    "postcss": "catalog:tailwind4",
    "storybook": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
