{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NEXT_PUBLIC_APP_URL", "SERVICE_JWT_SECRET", "VITE_*"],
      "passThroughEnv": ["HOST", "PORT", "PORTLESS_URL"],
      "inputs": ["$TURBO_DEFAULT$", "../app/.vercel/.env*", ".vercel/.env*"],
      "outputs": [".output/**", "dist/**", "src/routeTree.gen.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["HOST", "PORT", "PORTLESS_URL"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
