{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SENTRY_DSN",
        "NEXT_PUBLIC_BETTERSTACK_SOURCE_TOKEN",
        "NEXT_PUBLIC_BETTERSTACK_INGESTING_HOST",
        "NEXT_PUBLIC_VERCEL_ENV"
      ],
      "passThroughEnv": [
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "CLERK_SECRET_KEY",
        "BETTERSTACK_SOURCE_TOKEN",
        "BETTERSTACK_INGESTING_HOST",
        "HEALTH_CHECK_AUTH_TOKEN",
        "ARCJET_KEY",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "next-env.d.ts"
      ]
    },
    "dev": {
      "persistent": true
    },
    "transit": {}
  }
}
