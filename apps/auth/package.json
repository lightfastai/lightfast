{
  "name": "@lightfast/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:prod",
    "build:dev": "pnpm with-env next build --turbopack",
    "build:prod": "pnpm with-env next build --turbopack",
    "clean": "git clean -xdf .cache .clerk .next .turbo .vercel node_modules",
    "dev": "export VC_MICROFRONTENDS_CONFIG=../../apps/console/microfrontends.json && pnpm with-env next dev --port $(microfrontends port) --turbo",
    "start": "pnpm with-env next start -p ${NEXT_PUBLIC_AUTH_PORT:-4104}",
    "test": "vitest run",
    "test:e2e": "pnpm with-env playwright test",
    "test:e2e:ui": "pnpm with-env playwright test --ui",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ./.vercel/.env.development.local --"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "@rescale/nemo": "^2.1.1",
    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@vendor/analytics": "workspace:*",
    "@vendor/clerk": "workspace:*",
    "@vendor/next": "workspace:*",
    "@vendor/observability": "workspace:*",
    "@vendor/security": "workspace:^",
    "@vendor/seo": "workspace:*",
    "@vendor/upstash": "workspace:*",
    "@vercel/microfrontends": "^2.3.0",
    "@vercel/related-projects": "catalog:",
    "geist": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:next16",
    "nuqs": "^2.8.9",
    "react": "19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "19.2.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind4",
    "@tailwindcss/typography": "catalog:tailwind4",
    "@types/node": "catalog:",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv-cli": "^8.0.0",
    "import-in-the-middle": "catalog:",
    "postcss": "catalog:tailwind4",
    "require-in-the-middle": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "FSL-1.1-Apache-2.0"
}
