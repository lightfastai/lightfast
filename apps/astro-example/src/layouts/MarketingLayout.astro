---
import { Font } from "astro:assets";
import SpeedInsights from "@vercel/speed-insights/astro";
import AboutSheet from "../components/marketing/AboutSheet.astro";
import Footer from "../components/marketing/Footer.astro";
import Header from "../components/marketing/Header.astro";
import "../styles/tailwind.css";

interface Props {
  canonical?: string;
  description?: string;
  keywords?: string[];
  ogType?: string;
  title?: string;
}

const {
  canonical = "https://lightfast.ai",
  description = "Lightfast is building infrastructure for AI work that needs memory, review, and human trust.",
  keywords,
  ogType = "website",
  title = "Lightfast",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <Font cssVariable="--font-geist" preload={[{ weight: 400, style: "normal" }]} />
    <Font cssVariable="--font-pp-neue-montreal" preload={[{ weight: 500, style: "normal" }]} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {
      keywords ? (
        <meta name="keywords" content={keywords.join(", ")} />
      ) : null
    }
    <meta name="author" content="Lightfast" />
    <meta name="creator" content="Lightfast" />
    <meta name="publisher" content="Lightfast" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Lightfast" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:site" content="@lightfastai" />
    <meta name="twitter:creator" content="@lightfastai" />
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body class="marketing-body" id="top">
    <Header />
    <div class="marketing-shift">
      <div class="marketing-content">
        <slot />
      </div>
      <Footer />
    </div>
    <AboutSheet />
    <script is:inline>
      const body = document.body;
      const layer = document.querySelector("[data-about-layer]");
      const panel = document.querySelector("[data-about-panel]");
      const openButtons = document.querySelectorAll("[data-about-open]");
      const closeButtons = document.querySelectorAll("[data-about-close]");
      let lastFocused = null;

      const setAboutOpen = (isOpen) => {
        body.toggleAttribute("data-about-open", isOpen);
        layer?.setAttribute("aria-hidden", isOpen ? "false" : "true");

        if (isOpen) {
          layer?.removeAttribute("inert");
          lastFocused = document.activeElement instanceof HTMLElement
            ? document.activeElement
            : null;
          window.setTimeout(() => panel?.focus(), 40);
          return;
        }

        layer?.setAttribute("inert", "");
        if (lastFocused instanceof HTMLElement) {
          lastFocused.focus();
        }
      };

      openButtons.forEach((button) => {
        button.addEventListener("click", () => setAboutOpen(true));
      });

      closeButtons.forEach((button) => {
        button.addEventListener("click", () => setAboutOpen(false));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && body.hasAttribute("data-about-open")) {
          setAboutOpen(false);
        }
      });
    </script>
    <SpeedInsights />
  </body>
</html>

<style is:global>
  :root {
    --background: oklch(1 0 0);
    --foreground: oklch(0.277 0 0);
    --primary: oklch(0.209 0 0);
    --primary-foreground: oklch(1 0 0);
    --secondary: oklch(0.946 0 0);
    --secondary-foreground: oklch(0.277 0 0);
    --muted: oklch(0.964 0 0);
    --muted-foreground: oklch(0.478 0 0);
    --border: oklch(0.159 0 0 / 10%);
    --ring: oklch(0.529 0.173 254.975);
    --font-title: var(--font-pp-neue-montreal), var(--font-geist), sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  html {
    scroll-behavior: smooth;
  }

  body.marketing-body {
    background: var(--background);
    color: var(--foreground);
    font-family: var(--font-geist);
    letter-spacing: 0;
    overflow-x: clip;
  }

  .marketing-body a {
    color: inherit;
  }

  .sr-only {
    clip: rect(0, 0, 0, 0);
    border: 0;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .marketing-header,
  .marketing-shift {
    transition-duration: 650ms;
    transition-property: transform;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  body[data-about-open] .marketing-header,
  body[data-about-open] .marketing-shift {
    transform: translateX(-5%);
    transition-duration: 1250ms;
  }

  .marketing-header {
    background: var(--background);
    inset: 0 0 auto;
    padding: 12px 24px;
    position: fixed;
    z-index: 50;
  }

  .marketing-header-nav {
    align-items: center;
    display: flex;
    gap: 32px;
    height: 40px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1960px;
    width: 100%;
  }

  .marketing-logo-link {
    color: var(--foreground);
    display: inline-flex;
    flex-shrink: 0;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .marketing-logo-link:hover {
    color: var(--muted-foreground);
  }

  .brand-logo {
    align-items: center;
    display: inline-flex;
    flex-shrink: 0;
  }

  .brand-logo--sm {
    gap: 6.1px;
    --logo-mark-size: 22px;
    --logo-wordmark-size: 23.5px;
  }

  .brand-logo--md {
    gap: 8.75px;
    --logo-mark-size: 31.3px;
    --logo-wordmark-size: 33.5px;
  }

  .brand-logo--lg {
    gap: 11.2px;
    --logo-mark-size: 40px;
    --logo-wordmark-size: 42.8px;
  }

  .brand-logo-mark {
    flex-shrink: 0;
    height: var(--logo-mark-size);
    overflow: visible;
    width: var(--logo-mark-size);
  }

  .brand-logo-wordmark {
    flex-shrink: 0;
    height: calc(var(--logo-wordmark-size) * 0.92);
    overflow: visible;
    width: calc(var(--logo-wordmark-size) * 4.155);
  }

  .marketing-nav-links {
    align-items: center;
    display: flex;
    gap: 40px;
  }

  .marketing-link-button,
  .marketing-footer-link {
    appearance: none;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    line-height: 1.25;
    padding: 0;
    text-align: left;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .marketing-link-button:hover,
  .marketing-link-button:focus-visible,
  .marketing-footer-link:hover,
  .marketing-footer-link:focus-visible {
    color: var(--muted-foreground);
    outline: none;
  }

  .marketing-content {
    min-height: 100svh;
    padding-bottom: 80px;
  }

  .marketing-footer {
    background: var(--background);
    color: var(--foreground);
    min-height: calc(100svh - 4rem);
    padding: 0 24px;
  }

  .marketing-footer-frame {
    margin: 0 auto;
    max-width: 1960px;
    width: 100%;
  }

  .marketing-footer-inner {
    align-items: stretch;
    display: flex;
    flex-direction: column;
    gap: clamp(5rem, 18vh, 12.5rem);
    justify-content: space-between;
    min-height: calc(100svh - 4rem);
    padding: 28px 0;
  }

  .marketing-footer-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: 100%;
  }

  .marketing-footer-column {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .marketing-footer-newsletter {
    grid-column: span 2;
  }

  .marketing-footer-label,
  .marketing-newsletter-note,
  .marketing-footer-bottom {
    color: var(--muted-foreground);
    font-size: 12px;
    line-height: 1.25;
  }

  .marketing-footer-label,
  .marketing-newsletter-copy,
  .marketing-footer-bottom p {
    margin: 0;
  }

  .marketing-footer-stack {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .marketing-footer-link {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.25;
    padding: 2px 0;
  }

  .marketing-newsletter-copy {
    color: var(--foreground);
    font-size: 16px;
    line-height: 1.25;
    max-width: 30rem;
  }

  .marketing-newsletter-wrap {
    width: 100%;
  }

  .marketing-newsletter-form {
    align-items: center;
    display: flex;
    position: relative;
    width: 100%;
  }

  .marketing-newsletter-form input {
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: 0;
    color: var(--foreground);
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    line-height: 1.25;
    margin: 0;
    outline: none;
    padding: 12px 128px 12px 12px;
    transition: border-color 180ms ease;
    width: 100%;
  }

  .marketing-newsletter-form input::placeholder {
    color: var(--foreground);
  }

  .marketing-newsletter-form input:hover {
    border-color: color-mix(in oklab, var(--muted-foreground) 30%, transparent);
  }

  .marketing-newsletter-form input:focus {
    border-color: var(--ring);
  }

  .marketing-newsletter-form button {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--foreground);
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    font-size: 12px;
    gap: 8px;
    inset: 0 0 0 auto;
    line-height: 1.25;
    padding: 12px;
    position: absolute;
    transition: color 180ms ease;
  }

  .marketing-newsletter-form button:hover,
  .marketing-newsletter-form button:focus-visible {
    color: var(--muted-foreground);
    outline: none;
  }

  .marketing-newsletter-form svg,
  .marketing-footer-top svg {
    height: 16px;
    width: 16px;
  }

  .marketing-newsletter-note {
    margin: 8px 0 0;
  }

  .marketing-newsletter-note a,
  .marketing-footer-bottom a {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .marketing-footer-bottom {
    align-items: center;
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: 100%;
  }

  .marketing-footer-bottom > div {
    display: flex;
    justify-content: center;
  }

  .marketing-footer-bottom-copy {
    justify-content: flex-start;
  }

  .marketing-footer-privacy {
    align-items: center;
    gap: 20px;
    justify-content: flex-end !important;
  }

  .marketing-footer-top {
    align-items: center;
    display: none;
    gap: 4px;
    text-decoration: none !important;
  }

  .about-layer {
    inset: 0;
    pointer-events: none;
    position: fixed;
    visibility: hidden;
    z-index: 60;
  }

  body[data-about-open] .about-layer {
    pointer-events: auto;
    visibility: visible;
  }

  .about-backdrop {
    appearance: none;
    background: color-mix(in oklab, var(--foreground) 12%, transparent);
    border: 0;
    cursor: pointer;
    inset: 0;
    opacity: 0;
    position: absolute;
    transition: opacity 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  body[data-about-open] .about-backdrop {
    opacity: 1;
  }

  .about-sheet {
    background: var(--background);
    border-left: 1px solid var(--border);
    color: var(--foreground);
    height: 100svh;
    max-width: 100vw;
    overflow-y: auto;
    position: fixed;
    right: 0;
    top: 0;
    transform: translateX(100%);
    transition: transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    width: min(42rem, 100vw);
    will-change: transform;
  }

  body[data-about-open] .about-sheet {
    transform: translateX(0);
    transition-duration: 1250ms;
  }

  .about-sheet:focus {
    outline: none;
  }

  .about-close {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--foreground);
    cursor: pointer;
    display: inline-flex;
    height: 40px;
    justify-content: center;
    padding: 0;
    position: absolute;
    right: 24px;
    top: 20px;
    width: 40px;
    z-index: 1;
  }

  .about-close svg {
    height: 22px;
    width: 22px;
  }

  .about-sheet-inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 28px 24px 40px;
  }

  .about-kicker,
  .about-principles-heading {
    align-items: center;
    display: flex;
    gap: 12px;
  }

  .about-dot {
    background: var(--foreground);
    border-radius: 999px;
    display: inline-flex;
    flex-shrink: 0;
    height: 8px;
    width: 8px;
  }

  .about-kicker h2 {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
  }

  .about-intro {
    color: var(--foreground);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.35;
    margin-top: 32px;
    text-wrap: pretty;
  }

  .about-intro-paragraph {
    margin: 0 0 24px;
  }

  .about-intro-paragraph:last-child {
    margin-bottom: 0;
  }

  .about-intro-line {
    display: block;
    overflow: hidden;
  }

  .about-intro-line-inner {
    display: block;
    opacity: 0;
    transform: translateY(150%);
    transition-duration: 1250ms;
    transition-property: opacity, transform;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  body[data-about-open] .about-intro-line-inner {
    opacity: 1;
    transform: translateY(0);
    transition-delay: var(--delay);
  }

  .about-media-section {
    margin-top: 64px;
  }

  .about-media-meta {
    align-items: center;
    color: var(--muted-foreground);
    display: flex;
    font-size: 12px;
    justify-content: space-between;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .about-media-card {
    aspect-ratio: 4 / 5;
    background: var(--primary);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--primary-foreground);
    overflow: hidden;
    position: relative;
  }

  .about-media-words {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
    padding: 20px;
    transform: scale(1.05);
    transition: transform 1075ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  body[data-about-open] .about-media-words {
    transform: scale(1);
  }

  .about-media-words span {
    display: block;
    font-size: 40px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
  }

  .about-media-cover {
    background: var(--secondary);
    inset: 0;
    position: absolute;
    transition: opacity 1075ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  body[data-about-open] .about-media-cover {
    opacity: 0;
  }

  .about-principles {
    border-top: 1px solid var(--border);
    display: grid;
    gap: 38px;
    margin-top: 38px;
    padding-top: 38px;
  }

  .about-principles-heading {
    align-self: start;
  }

  .about-principles-heading h3 {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
  }

  .about-principles-list {
    display: grid;
    margin: 0;
  }

  .about-principle {
    border-bottom: 1px solid var(--border);
    display: grid;
    gap: 23px;
    margin-bottom: 38px;
    padding-bottom: 38px;
  }

  .about-principle:last-child {
    border-bottom: 0;
    margin-bottom: 0;
  }

  .about-principle dt,
  .about-principle dd {
    color: var(--foreground);
    font-size: 16px;
    letter-spacing: 0;
    margin: 0;
  }

  .about-principle dt {
    font-weight: 500;
    line-height: 1;
  }

  .about-principle dd {
    line-height: 1.3;
  }

  @media (min-width: 640px) {
    .marketing-header,
    .marketing-footer {
      padding-left: 40px;
      padding-right: 40px;
    }

    .about-intro {
      font-size: 24px;
    }

    .about-media-words span {
      font-size: 48px;
    }

    .about-principles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-principles-heading h3 {
      font-size: 24px;
    }

    .about-principle dt,
    .about-principle dd {
      font-size: 17.5px;
    }
  }

  @media (max-width: 991px) {
    .marketing-footer-grid,
    .marketing-footer-bottom {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .marketing-footer-bottom-copy {
      justify-content: flex-end !important;
      order: 9999;
    }

    .marketing-footer-bottom > div:nth-child(3) {
      order: -9999;
    }

    .marketing-footer-privacy {
      justify-content: flex-start !important;
    }
  }

  @media (max-width: 767px) {
    .marketing-footer-inner {
      gap: 6.25rem;
    }
  }

  @media (max-width: 520px) {
    .marketing-header {
      padding-left: 16px;
      padding-right: 16px;
    }

    .marketing-header-nav {
      gap: 14px;
    }

    .marketing-nav-links {
      gap: 14px;
    }

    .marketing-link-button {
      font-size: 14px;
    }

    .marketing-footer-grid {
      grid-template-columns: 1fr;
    }

    .marketing-footer-newsletter {
      grid-column: auto;
    }

    .marketing-footer-bottom {
      gap: 12px;
    }

    .marketing-newsletter-copy {
      max-width: 13.13rem;
    }
  }
</style>
