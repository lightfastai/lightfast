---
const { frontmatter } = Astro.props;

const pageTitle = frontmatter.title;
const description = frontmatter.description;
const canonical = frontmatter.canonical;
const keywords = frontmatter.keywords;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://lightfast.ai/#organization",
      name: "Lightfast",
      url: "https://lightfast.ai",
      logo: {
        "@type": "ImageObject",
        url: "https://lightfast.ai/android-chrome-512x512.png",
      },
      sameAs: [
        "https://twitter.com/lightfastai",
        "https://github.com/lightfastai",
        "https://www.linkedin.com/company/lightfastai",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://lightfast.ai/#website",
      url: "https://lightfast.ai",
      name: "Lightfast",
      publisher: {
        "@id": "https://lightfast.ai/#organization",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: pageTitle,
      description,
      isPartOf: { "@id": "https://lightfast.ai/#website" },
      publisher: { "@id": "https://lightfast.ai/#organization" },
      dateModified: frontmatter.updatedAt,
    },
  ],
};
---

<MarketingLayout
  canonical={canonical}
  description={description}
  keywords={keywords}
  title={`${pageTitle} | Lightfast`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <article class="brand-page">
    <section class="brand-hero">
      <div class="brand-hero-inner">
        <h1>{pageTitle}</h1>
        <a class="brand-contact-button" href="#contact">Contact</a>
      </div>
    </section>

    <section aria-label="Lightfast logo preview" class="brand-showcase">
      <div class="brand-showcase-panel">
        <div class="brand-showcase-header">
          <span></span>
          <span>Wordmarks</span>
          <span></span>
        </div>
        <div class="brand-showcase-logo-wrap">
          <Logo size="lg" />
        </div>
      </div>
    </section>

    <div class="brand-doc-wrap">
      <div class="brand-doc">
        <slot />
      </div>
    </div>
  </article>
</MarketingLayout>

<style is:global>
  .brand-page {
    background: var(--background);
    color: var(--foreground);
    width: 100%;
  }

  .brand-hero {
    align-items: flex-start;
    display: flex;
    justify-content: center;
    padding: 160px 24px 64px;
    text-align: center;
  }

  .brand-hero-inner {
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .brand-hero h1 {
    color: var(--foreground);
    font-family: var(--font-title);
    font-size: 48px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    margin: 0;
  }

  .brand-contact-button {
    align-items: center;
    background: var(--secondary);
    border-radius: 8px;
    color: var(--secondary-foreground);
    display: inline-flex;
    font-size: 15px;
    font-weight: 500;
    justify-content: center;
    line-height: 1;
    margin-top: 40px;
    min-height: 44px;
    padding: 0 22px;
    text-decoration: none;
    transition: background-color 180ms ease, color 180ms ease;
  }

  .brand-contact-button:hover,
  .brand-contact-button:focus-visible {
    background: var(--primary);
    color: var(--primary-foreground);
    outline: none;
  }

  .brand-showcase {
    padding: 0 24px 80px;
  }

  .brand-showcase-panel {
    aspect-ratio: 16 / 9;
    background: var(--foreground);
    border-radius: 6px;
    color: var(--background);
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    max-width: 1620px;
    overflow: hidden;
    padding: 64px 48px;
  }

  .brand-showcase-header {
    align-items: start;
    color: var(--background);
    display: grid;
    font-size: 10px;
    grid-template-columns: 1fr auto 1fr;
    line-height: 1;
  }

  .brand-showcase-logo-wrap {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: center;
  }

  .brand-doc-wrap {
    padding: 0 24px;
  }

  .brand-doc {
    margin: 0 auto;
    max-width: 672px;
    padding: 64px 0 96px;
  }

  .brand-doc h2,
  .brand-doc h3 {
    color: var(--foreground);
    font-family: var(--font-title);
    font-weight: 500;
    letter-spacing: 0;
    scroll-margin-top: 96px;
  }

  .brand-doc h2 {
    font-size: 30px;
    line-height: 1.1;
    margin: 80px 0 0;
  }

  .brand-doc h2:first-child {
    margin-top: 0;
  }

  .brand-doc h3 {
    font-size: 20px;
    line-height: 1.2;
    margin: 32px 0 16px;
  }

  .brand-doc p,
  .brand-doc li {
    color: var(--foreground);
    font-size: 16px;
    line-height: 1.55;
    overflow-wrap: break-word;
  }

  .brand-doc p {
    margin: 24px 0 0;
  }

  .brand-doc a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--foreground) 40%, transparent);
    text-underline-offset: 2px;
    transition: text-decoration-color 180ms ease;
  }

  .brand-doc a:hover,
  .brand-doc a:focus-visible {
    text-decoration-color: var(--foreground);
  }

  .brand-doc ul {
    display: grid;
    gap: 8px;
    list-style: disc;
    margin: 12px 0 0 24px;
    padding: 0;
  }

  .brand-doc table {
    border-collapse: collapse;
    display: block;
    margin: 40px 0;
    overflow-x: auto;
    width: 100%;
  }

  .brand-doc thead {
    border-bottom: 1px solid color-mix(in oklab, var(--border) 50%, transparent);
  }

  .brand-doc tr {
    border-bottom: 1px solid color-mix(in oklab, var(--border) 30%, transparent);
  }

  .brand-doc tbody tr:last-child {
    border-bottom: 0;
  }

  .brand-doc th,
  .brand-doc td {
    font-size: 14px;
    line-height: 1.45;
    padding: 16px;
    text-align: left;
    vertical-align: top;
  }

  .brand-doc th {
    font-weight: 600;
  }

  @media (min-width: 640px) {
    .brand-hero {
      padding-left: 40px;
      padding-right: 40px;
      padding-top: 128px;
    }

    .brand-showcase,
    .brand-doc-wrap {
      padding-left: 40px;
      padding-right: 40px;
    }

    .brand-showcase-panel {
      padding-left: 80px;
      padding-right: 80px;
    }

    .brand-doc {
      padding-bottom: 128px;
      padding-top: 96px;
    }

    .brand-doc h2 {
      font-size: 36px;
    }
  }

  @media (min-width: 1024px) {
    .brand-showcase-panel {
      padding-left: 112px;
      padding-right: 112px;
    }
  }

  @media (max-width: 520px) {
    .brand-hero h1 {
      font-size: 42px;
    }

    .brand-showcase-panel {
      padding: 36px 24px;
    }
  }
</style>
