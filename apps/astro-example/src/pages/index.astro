---
import { getImage } from "astro:assets";
import halftoneBackground from "../assets/images/landing-halftone-bg.png";

const title = "A Git Forge for the Agentic Era";
const description =
  "Lightfast is building infrastructure for code moving faster than existing systems were built to handle.";

const halftoneAvif = await getImage({
  src: halftoneBackground,
  format: "avif",
  quality: 40,
});
const halftoneWebp = await getImage({
  src: halftoneBackground,
  format: "webp",
  quality: 40,
});
const halftoneImageSet = `image-set(url("${halftoneAvif.src}") type("image/avif"), url("${halftoneWebp.src}") type("image/webp"))`;
const wordmarkViewBox = "0 -716 4155 920";
const wordmarkPath =
  "M193 0Q78 0 78 -115V-700H182V-127Q182 -92 217 -92H523V0ZM605 0V-504H702V0ZM653 -590Q627 -590 608.5 -608.5Q590 -627 590 -653Q590 -679 608.5 -697.5Q627 -716 653 -716Q679 -716 697.5 -697.5Q716 -679 716 -653Q716 -627 697.5 -608.5Q679 -590 653 -590ZM878 204V123H1111Q1155 123 1183.0 93.5Q1211 64 1211 18V-64Q1192 -32 1147.5 -12.0Q1103 8 1048 8Q973 8 920.0 -26.0Q867 -60 839.0 -119.0Q811 -178 811 -252Q811 -327 839.0 -385.5Q867 -444 920.0 -478.0Q973 -512 1049 -512Q1098 -512 1142.5 -491.5Q1187 -471 1211 -437V-504H1308V24Q1308 105 1257.0 154.5Q1206 204 1121 204ZM1064 -77Q1134 -77 1176.0 -125.0Q1218 -173 1218 -252Q1218 -331 1176.0 -379.0Q1134 -427 1064 -427Q994 -427 951.5 -379.0Q909 -331 909 -252Q909 -173 951.5 -125.0Q994 -77 1064 -77ZM1450 0V-715H1547V-415Q1567 -462 1610.0 -487.0Q1653 -512 1709 -512Q1766 -512 1808.5 -486.5Q1851 -461 1874.0 -415.5Q1897 -370 1897 -310V0H1800V-291Q1800 -351 1767.5 -388.0Q1735 -425 1682 -425Q1623 -425 1585.0 -382.0Q1547 -339 1547 -273V0ZM2235 0Q2159 0 2113.0 -44.0Q2067 -88 2067 -165V-420H1964V-504H2038Q2067 -504 2067 -533V-662H2164V-504H2313V-420H2164V-168Q2164 -128 2185.0 -106.0Q2206 -84 2242 -84H2313V0ZM2455 0V-420H2352V-504H2455V-553Q2455 -627 2500.0 -671.0Q2545 -715 2621 -715H2705V-631H2629Q2594 -631 2573.0 -609.5Q2552 -588 2552 -550V-504H2705V-420H2552V0ZM2978 8Q2902 8 2848.5 -26.0Q2795 -60 2767.0 -119.0Q2739 -178 2739 -252Q2739 -327 2767.0 -385.5Q2795 -444 2848.0 -478.0Q2901 -512 2977 -512Q3026 -512 3070.0 -491.5Q3114 -471 3139 -437V-504H3236V0H3139V-68Q3116 -34 3073.5 -13.0Q3031 8 2978 8ZM2992 -77Q3062 -77 3104.0 -125.0Q3146 -173 3146 -252Q3146 -331 3104.0 -379.0Q3062 -427 2992 -427Q2922 -427 2879.5 -379.0Q2837 -331 2837 -252Q2837 -173 2879.5 -125.0Q2922 -77 2992 -77ZM3544 8Q3453 8 3400.0 -37.0Q3347 -82 3341 -164H3430Q3434 -121 3464.0 -96.0Q3494 -71 3543 -71Q3588 -71 3615.0 -91.0Q3642 -111 3642 -145Q3642 -176 3621.0 -190.5Q3600 -205 3567.5 -211.5Q3535 -218 3498.0 -224.0Q3461 -230 3428.5 -243.5Q3396 -257 3375.0 -284.5Q3354 -312 3354 -362Q3354 -407 3377.0 -440.5Q3400 -474 3441.0 -493.0Q3482 -512 3534 -512Q3622 -512 3673.0 -470.5Q3724 -429 3729 -355H3640Q3636 -392 3607.5 -414.0Q3579 -436 3535 -436Q3498 -436 3471.0 -418.0Q3444 -400 3444 -366Q3444 -336 3465.0 -322.5Q3486 -309 3519.0 -303.5Q3552 -298 3588.5 -292.0Q3625 -286 3658.0 -273.0Q3691 -260 3712.0 -231.5Q3733 -203 3733 -150Q3733 -77 3682.5 -34.5Q3632 8 3544 8ZM4052 0Q3976 0 3930.0 -44.0Q3884 -88 3884 -165V-420H3781V-504H3855Q3884 -504 3884 -533V-662H3981V-504H4130V-420H3981V-168Q3981 -128 4002.0 -106.0Q4023 -84 4059 -84H4130V0Z";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://lightfast.ai/#organization",
      name: "Lightfast",
      url: "https://lightfast.ai",
      logo: {
        "@type": "ImageObject",
        url: "https://lightfast.ai/android-chrome-512x512.png",
      },
      sameAs: [
        "https://twitter.com/lightfastai",
        "https://github.com/lightfastai",
        "https://www.linkedin.com/company/lightfastai",
      ],
      description,
    },
    {
      "@type": "WebSite",
      "@id": "https://lightfast.ai/#website",
      url: "https://lightfast.ai",
      name: "Lightfast",
      description: "A git forge for the agentic era.",
      publisher: {
        "@id": "https://lightfast.ai/#organization",
      },
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://lightfast.ai/#software",
      name: "Lightfast",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
        url: "https://lightfast.ai/sign-up",
      },
      description:
        "A git forge for the agentic era, designed for code moving faster than existing infrastructure was built to handle.",
      featureList: [
        "Agentic software development infrastructure",
        "Developer workflows for AI-assisted code",
        "Version control workflows for modern software teams",
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="preload"
      as="image"
      href={halftoneAvif.src}
      type="image/avif"
      media="(min-width: 768px)"
    />
    <Font cssVariable="--font-geist" preload={[{ weight: 400, style: "normal" }]} />
    <Font cssVariable="--font-pp-neue-montreal" preload={[{ weight: 500, style: "normal" }]} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI developer tools, agentic coding, git forge, software agents, AI infrastructure, developer infrastructure, Lightfast"
    />
    <meta name="author" content="Lightfast" />
    <meta name="creator" content="Lightfast" />
    <meta name="publisher" content="Lightfast" />
    <link rel="canonical" href="https://lightfast.ai" />
    <meta property="og:title" content="Lightfast - A Git Forge for the Agentic Era" />
    <meta property="og:description" content="Infrastructure for code moving faster than existing systems were built to handle." />
    <meta property="og:url" content="https://lightfast.ai" />
    <meta property="og:site_name" content="Lightfast" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Lightfast - A Git Forge for the Agentic Era" />
    <meta name="twitter:description" content="Infrastructure for code moving faster than existing systems were built to handle." />
    <meta name="twitter:site" content="@lightfastai" />
    <meta name="twitter:creator" content="@lightfastai" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <section class="sr-only" aria-label="Lightfast answer summary">
      <h1>What is Lightfast?</h1>
      <p>
        Lightfast is the operating layer between AI agents, apps, and teams. It
        helps teams observe workspace events, preserve durable memory, review
        long-running agent work, and act across tools with source-cited context.
      </p>
      <h2>Who is Lightfast for?</h2>
      <p>
        Lightfast is for engineering teams, founders, and agent builders who
        need AI workflows to survive handoffs, retries, reviews, and production
        changes.
      </p>
    </section>

    <main class="landing" style="--guide-x: 24.58%; --guide-y: clamp(108px, calc(45.9svh - 180px), 27.55%);">
      <div class="mobile-gradient" aria-hidden="true"></div>
      <div
        class="halftone-background"
        aria-hidden="true"
        style={`--halftone-background: ${halftoneImageSet};`}
      />
      <div class="scrim" aria-hidden="true"></div>
      <div class="decorative-guides" aria-hidden="true">
        <div class="horizontal-guide"></div>
        <div class="vertical-guide"></div>
        <svg class="guide-art" fill="none" preserveAspectRatio="none" viewBox="0 0 1440 900">
          <path
            d="M175 -8 C128 206 116 548 275 748 C432 945 806 833 1448 368"
            stroke="rgba(255,255,255,0.82)"
            stroke-width="1.1"
          ></path>
          <path
            d="M1160 -2 L1446 280"
            stroke="rgba(255,255,255,0.86)"
            stroke-dasharray="6 8"
            stroke-width="1.2"
          ></path>
        </svg>
      </div>

      <section class="hero">
        <div class="hero-content">
          <a aria-label="Lightfast home" class="lockup" href="/">
            <svg class="mark" aria-hidden="true" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M8 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M8 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M8 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M20 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M20 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M20 16a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 76a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 64a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M20 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 16a4 4 0 1 0-8 0 4 4 0 0 0 8 0M68 16a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 16a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 4a4 4 0 1 0-8 0 4 4 0 0 0 8 0M68 64a4 4 0 1 0-8 0 4 4 0 0 0 8 0M68 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M68 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M80 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M68 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 76a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 64a4 4 0 1 0-8 0 4 4 0 0 0 8 0M20 64a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 16a4 4 0 1 0-8 0 4 4 0 0 0 8 0M32 4a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 76a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 64a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M56 4a4 4 0 1 0-8 0 4 4 0 0 0 8 0M80 52a4 4 0 1 0-8 0 4 4 0 0 0 8 0M44 40a4 4 0 1 0-8 0 4 4 0 0 0 8 0M80 28a4 4 0 1 0-8 0 4 4 0 0 0 8 0"
                fill="currentColor"
              ></path>
            </svg>
            <svg
              aria-label="Lightfast"
              class="lockup-wordmark"
              focusable="false"
              role="img"
              viewBox={wordmarkViewBox}
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d={wordmarkPath} fill="currentColor"></path>
            </svg>
          </a>

          <h1 class="headline">
            A git forge for
            <br />
            the agentic era
          </h1>

          <p class="dek">
            Code is moving faster than any infrastructure was built to handle.
            <br />
            Origin was designed for this moment.
          </p>

          <form class="waitlist-form" id="landing-waitlist" method="get">
            <label class="form-label" for="landing-email">Join the waitlist</label>
            <div class="input-wrap">
              <input
                id="landing-email"
                inputmode="email"
                name="email"
                placeholder="Enter your work email"
                required
                type="email"
              />
              <button aria-label="Join the waitlist" disabled type="submit">
                <svg aria-hidden="true" class="arrow-icon" fill="none" viewBox="0 0 24 24">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"></path>
                </svg>
              </button>
            </div>
            <p class="consent">
              By joining, you agree to receive early access updates. See our
              <a href="/legal/privacy">Privacy Policy</a>.
            </p>
          </form>
        </div>
      </section>
    </main>

    <script is:inline>
      const form = document.querySelector("#landing-waitlist");
      const input = document.querySelector("#landing-email");
      const button = form?.querySelector("button");

      const syncButton = () => {
        if (!button || !(input instanceof HTMLInputElement)) return;
        button.disabled = input.value.trim().length === 0;
      };

      form?.addEventListener("submit", (event) => event.preventDefault());
      input?.addEventListener("input", syncButton);
      syncButton();
    </script>
    <SpeedInsights />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
  }

  :global(body) {
    background: #14120b;
    color: #edecec;
    font-family: var(--font-geist);
  }

  :global(a) {
    color: inherit;
  }

  .sr-only {
    clip: rect(0, 0, 0, 0);
    border: 0;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .landing {
    background: #14120b;
    color: #edecec;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    position: relative;
    selection-color: #edecec;
    width: 100%;
  }

  .mobile-gradient {
    background: linear-gradient(115deg, #1d3d56 0%, #6e9aaa 48%, #060c09 100%);
    inset: 0;
    position: absolute;
  }

  .halftone-background {
    display: none;
  }

  .scrim {
    background: rgb(0 0 0 / 20%);
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .decorative-guides {
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .horizontal-guide {
    background: rgb(255 255 255 / 10%);
    height: 1px;
    left: 0;
    position: absolute;
    right: 0;
    top: var(--guide-y);
  }

  .vertical-guide {
    background: rgb(255 255 255 / 10%);
    bottom: 0;
    left: var(--guide-x);
    position: absolute;
    top: 0;
    width: 1px;
  }

  .guide-art {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .hero {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: auto 1fr;
    min-height: 100%;
    padding: 1.5rem;
    position: relative;
    width: 100%;
    z-index: 10;
  }

  .hero-content {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    grid-column: span 2;
    grid-row-start: 1;
    max-width: 100%;
    min-width: 0;
    text-align: left;
    width: 100%;
  }

  .lockup {
    align-items: center;
    display: inline-flex;
    gap: 8.75px;
    height: 40px;
    opacity: 1;
    text-decoration: none;
    transition: opacity 200ms ease-out;
  }

  .lockup:hover {
    opacity: 0.7;
  }

  .mark {
    height: 31.3px;
    width: 31.3px;
  }

  .lockup-wordmark {
    height: 30.77px;
    width: 139px;
  }

  .headline {
    font-family: var(--font-pp-neue-montreal);
    font-size: 52px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.1;
    margin: 38.39px 0 0;
    max-width: 684px;
    padding-right: 2.5rem;
    text-wrap: balance;
    width: 100%;
  }

  .dek {
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 24px;
    margin: 15.2px 0 0;
    max-width: 100%;
    width: 520px;
  }

  .waitlist-form {
    margin-top: 30.39px;
    position: relative;
    text-align: left;
    width: 100%;
  }

  .form-label {
    display: block;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 24px;
    margin-bottom: 7.5px;
  }

  .input-wrap {
    height: 48px;
    position: relative;
  }

  input {
    background: #fff;
    border: 1px solid #edecec;
    border-radius: 8px;
    caret-color: #171717;
    color: #171717;
    font: inherit;
    font-size: 16px;
    height: 48px;
    line-height: 24px;
    outline: none;
    padding: 8.96px 56px 9.28px 20px;
    text-align: left;
    transition: border-color 200ms, background-color 200ms;
    width: 100%;
  }

  input::placeholder {
    color: #737373;
  }

  input:focus,
  input:hover {
    background: #fff;
    border-color: #fff;
  }

  button {
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: 4px;
    color: #fff;
    display: grid;
    height: 40px;
    justify-items: center;
    opacity: 0.4;
    padding: 0;
    place-items: center;
    position: absolute;
    right: 4px;
    top: 50%;
    transform: translateY(-50%);
    transition: background-color 200ms, color 200ms, opacity 200ms;
    width: 40px;
  }

  button:not(:disabled) {
    background: #14120b;
    cursor: pointer;
    opacity: 1;
  }

  button:disabled {
    pointer-events: none;
  }

  .arrow-icon {
    height: 16px;
    width: 16px;
  }

  .consent {
    color: rgb(237 236 236 / 75%);
    font-size: 12px;
    line-height: 20px;
    margin: 12px 0 0;
    max-width: 520px;
  }

  .consent a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 639px) {
    .headline {
      font-size: 44px;
      padding-right: 0;
    }
  }

  @media (max-width: 767px) {
    .hero-content,
    .headline,
    .dek,
    .waitlist-form,
    .consent {
      max-width: calc(100vw - 3rem);
    }

    .dek {
      width: 100%;
    }
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .hero-content {
      grid-column: span 2;
    }

    .mobile-gradient {
      display: none;
    }

    .halftone-background {
      background-image: var(--halftone-background);
      background-position: center;
      background-size: cover;
      display: block;
      height: 100%;
      inset: 0;
      position: absolute;
      width: 100%;
      z-index: 0;
    }
  }

  @media (min-width: 1024px) {
    .landing {
      min-height: 640px;
    }

    .scrim {
      background: rgb(0 0 0 / 25%);
    }

    .hero {
      gap: 1.5rem;
      grid-template-rows: 1fr auto 1fr;
    }

    .hero-content {
      align-self: center;
      grid-column: 2 / span 2;
      grid-row-start: 2;
    }
  }

  @media (max-width: 1023px) {
    .landing {
      min-height: 100svh;
    }
  }
</style>
