{
  "name": "@lightfast/www",
  "version": "0.1.0",
  "private": true,
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "pnpm build:prod",
    "build:dev": "pnpm with-env next build --turbopack",
    "build:prod": "pnpm with-env next build --turbopack",
    "postinstall": "fumadocs-mdx",
    "prebuild": "pnpm --filter @repo/app-openapi generate:openapi && tsx scripts/validate-schema-docs.ts",
    "search:sync": "mxbai store sync $MXBAI_STORE_ID \"./src/content/**/*.mdx\" --api-key $MXBAI_API_KEY",
    "search:sync:ci": "mxbai store sync $MXBAI_STORE_ID \"./src/content/**/*.mdx\" --api-key $MXBAI_API_KEY -y",
    "clean": "git clean -xdf .cache .clerk .next .turbo .vercel node_modules",
    "dev": "export VC_MICROFRONTENDS_CONFIG=../../apps/app/microfrontends.json && pnpm with-env next dev --port $(microfrontends port) --turbopack",
    "start": "pnpm with-env next start -p ${NEXT_PUBLIC_WWW_PORT:-4101}",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cms:types": "pnpm with-env pnpm --filter @vendor/cms exec basehub generate",
    "cms:dev": "pnpm with-env pnpm --filter @vendor/cms exec basehub dev",
    "cms:analyze": "pnpm with-env pnpm --filter @vendor/cms exec basehub",
    "with-env": "dotenv -e ./.vercel/.env.development.local --"
  },
  "dependencies": {
    "@mixedbread/sdk": "^0.46.0",
    "@radix-ui/react-popover": "^1.1.14",
    "@repo/og": "workspace:*",
    "@repo/ui": "workspace:*",
    "@rescale/nemo": "^2.1.1",
    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@vendor/aeo": "workspace:*",
    "@vendor/analytics": "workspace:*",
    "@vendor/cms": "workspace:*",
    "@vendor/email": "workspace:*",
    "@vendor/inngest": "workspace:*",
    "@vendor/next": "workspace:*",
    "@vendor/observability": "workspace:*",
    "@vendor/security": "workspace:*",
    "@vendor/seo": "workspace:*",
    "@vercel/microfrontends": "^2.3.0",
    "@vercel/related-projects": "catalog:",
    "feed": "^5.2.0",
    "framer-motion": "^11.18.2",
    "fumadocs-core": "16.6.10",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "^10.3.16",
    "fumadocs-ui": "16.6.10",
    "geist": "catalog:",
    "github-slugger": "^2.0.0",
    "html2canvas-pro": "^1.6.6",
    "jspdf": "^4.2.1",
    "lucide-react": "catalog:",
    "next": "catalog:next16",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remove-markdown": "^0.6.3",
    "swr": "^2.4.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mixedbread/cli": "^2.3.0",
    "@repo/app-openapi": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind4",
    "@tailwindcss/typography": "catalog:tailwind4",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv-cli": "^8.0.0",
    "import-in-the-middle": "catalog:",
    "jiti": "^1.21.6",
    "postcss": "catalog:tailwind4",
    "require-in-the-middle": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
