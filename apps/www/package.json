{
  "name": "@lightfast/www",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "portless": "www.lightfast",
  "scripts": {
    "build": "pnpm build:prod",
    "build:dev": "pnpm with-env next build",
    "build:prod": "pnpm with-env next build",
    "postinstall": "fumadocs-mdx",
    "search:sync": "mxbai store sync $MXBAI_STORE_ID \"./src/content/**/*.mdx\" --api-key $MXBAI_API_KEY",
    "search:sync:ci": "mxbai store sync $MXBAI_STORE_ID \"./src/content/**/*.mdx\" --api-key $MXBAI_API_KEY -y",
    "clean": "git clean -xdf .cache .clerk .next .turbo .vercel node_modules",
    "dev": "portless run pnpm with-related-projects pnpm with-env next dev --turbo",
    "start": "pnpm with-env next start -p 4101",
    "test": "vitest run",
    "typecheck": "pnpm with-env next typegen && tsc --noEmit",
    "with-env": "dotenv -e ./.vercel/.env.development.local --",
    "with-related-projects": "NEXT_PUBLIC_APP_URL=$(portless get lightfast) NEXT_PUBLIC_WWW_URL=$(portless get www.lightfast)"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "catalog:",
    "@hugeicons/react": "catalog:",
    "@logtail/next": "^0.3.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@repo/og": "workspace:*",
    "@repo/ui-v2": "workspace:*",
    "@rescale/nemo": "catalog:",
    "@sentry/browser": "catalog:",
    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@vendor/aeo": "workspace:*",
    "@vendor/analytics": "workspace:*",
    "@vendor/inngest": "workspace:*",
    "@vendor/next": "workspace:*",
    "@vendor/observability": "workspace:*",
    "@vendor/resend": "workspace:*",
    "@vendor/security": "workspace:*",
    "@vendor/seo": "workspace:*",
    "@vercel/microfrontends": "^2.3.2",
    "@vercel/related-projects": "catalog:",
    "@vercel/toolbar": "^0.2.2",
    "effect": "catalog:",
    "fumadocs-core": "16.6.10",
    "fumadocs-mdx": "14.2.9",
    "geist": "catalog:",
    "lodash.merge": "^4.6.2",
    "next": "catalog:next16",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mixedbread/cli": "^2.3.2",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind4",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv-cli": "catalog:",
    "import-in-the-middle": "catalog:",
    "jiti": "^2.6.1",
    "postcss": "catalog:tailwind4",
    "require-in-the-middle": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
