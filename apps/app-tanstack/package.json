{
  "name": "@lightfast/app-tanstack",
  "license": "Apache-2.0",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "portless": "app-tanstack.lightfast",
  "scripts": {
    "build": "pnpm with-env vite build",
    "clean": "git clean -xdf .cache .output .tanstack .turbo .vercel dist node_modules src/routeTree.gen.ts",
    "dev": "portless run pnpm with-related-projects pnpm with-env vite dev",
    "dev:next": "pnpm dev",
    "preview": "pnpm with-env vite preview",
    "start": "pnpm preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ./.env.overrides.local -e ./.vercel/.env.development.local -e ../app/.env.overrides.local -e ../app/.vercel/.env.development.local --",
    "with-env:local": "dotenv -e ./.env.overrides.local -e ./.vercel/.env.development.local -e ../app/.env.overrides.local -e ../app/.vercel/.env.development.local --",
    "with-env:vercel": "dotenv -e ./.vercel/.env.development.local -e ../app/.vercel/.env.development.local --",
    "with-related-projects": "env -S \"$(pnpm --silent --filter @repo/github-emulator env:sh -- --callback-url \"$(portless get lightfast)/api/github/setup\" --public-origin \"$(portless get github.lightfast)\")\n$(pnpm --silent --filter @repo/granola-emulator env:sh -- --public-origin \"$(portless get granola.lightfast)\")\n$(pnpm --silent --filter @repo/linear-emulator env:sh -- --public-origin \"$(portless get linear.lightfast)\")\n$(pnpm --silent --filter @repo/x-emulator env:sh -- --callback-url \"$(portless get lightfast)/api/connectors/x/mcp\" --public-origin \"$(portless get x.lightfast)\")\" INNGEST_SERVE_ORIGIN=$(portless get lightfast) NEXT_PUBLIC_APP_URL=$(portless get lightfast) NEXT_PUBLIC_WWW_URL=$(portless get www.lightfast) VITE_LIGHTFAST_APP_URL=$(portless get lightfast) VITE_LIGHTFAST_WWW_URL=$(portless get www.lightfast) VITE_SENTRY_DSN=${NEXT_PUBLIC_SENTRY_DSN:-} INNGEST_DEV=$(portless get inngest.lightfast) QSTASH_URL=$(portless get qstash.lightfast)"
  },
  "dependencies": {
    "@ai-sdk/react": "catalog:",
    "@api/app": "workspace:*",
    "@clerk/tanstack-react-start": "catalog:",
    "@db/app": "workspace:*",
    "@hookform/resolvers": "catalog:",
    "@orpc/openapi": "^1.14.2",
    "@repo/ai": "workspace:*",
    "@repo/api-contract": "workspace:*",
    "@repo/app-billing": "workspace:*",
    "@repo/app-setup-contract": "workspace:*",
    "@repo/app-validation": "workspace:*",
    "@repo/connector-contract": "workspace:*",
    "@repo/github-app-contract": "workspace:*",
    "@repo/native-auth-contract": "workspace:*",
    "@repo/provider-routine-contract": "workspace:*",
    "@repo/provider-routines": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/user-connector-contract": "workspace:*",
    "@sentry/tanstackstart-react": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@vendor/ai": "workspace:*",
    "@vendor/braintrust": "workspace:*",
    "@vendor/lib": "workspace:*",
    "@vendor/unkey": "workspace:*",
    "@vendor/upstash": "workspace:*",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-hook-form": "catalog:",
    "superjson": "catalog:",
    "tw-animate-css": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind4",
    "@tailwindcss/typography": "catalog:tailwind4",
    "@tanstack/router-plugin": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "dotenv-cli": "catalog:",
    "happy-dom": "catalog:",
    "nitro": "catalog:",
    "postcss": "catalog:tailwind4",
    "tailwindcss": "catalog:tailwind4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
