{
  "name": "@lightfast/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Lightfast desktop app (Electron Forge + plugin-vite + Fuses, macOS vibrancy sidebar, Sentry-ready).",
  "main": ".vite/build/bootstrap.js",
  "scripts": {
    "clean": "rm -rf out .vite .cache",
    "dev": "APP_URL=$(portless get lightfast) pnpm with-env electron-forge start",
    "devtools:reset": "node scripts/devtools-reset.mjs",
    "make": "electron-forge make",
    "metadata-probe": "node scripts/metadata-probe.mjs",
    "notices:generate": "node scripts/generate-third-party-notices.mjs",
    "package": "electron-forge package",
    "playwright:repl": "node scripts/playwright-electron-cdp.mjs",
    "pretest:e2e": "electron-forge package",
    "publish": "electron-forge publish",
    "predev": "pnpm rebuild:sqlite",
    "pretest": "pnpm rebuild:sqlite:node",
    "rebuild:sqlite": "node scripts/rebuild-sqlite.mjs --target=electron",
    "rebuild:sqlite:node": "node scripts/rebuild-sqlite.mjs --target=node",
    "sourcemaps:upload": "node scripts/upload-sourcemaps.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "with-env": "dotenv -e ./.vercel/.env.development.local --"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.1",
    "@playwright/test": "1.58.2",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@sentry/cli": "^2.39.1",
    "@t3-oss/env-core": "catalog:",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "dotenv-cli": "catalog:",
    "electron": "^41.3.0",
    "happy-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.10",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@api/app": "workspace:*",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@repo/native-auth-contract": "workspace:*",
    "@repo/native-auth-node": "workspace:*",
    "@sentry/electron": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@vendor/electron": "workspace:*",
    "@vendor/observability": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "electron-context-menu": "^4.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "sonner": "^2.0.6",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "buildFlavor": "dev",
  "buildNumber": "1",
  "sparkleFeedUrl": "",
  "signingMode": "ad-hoc"
}
