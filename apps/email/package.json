{
  "name": "@lightfast/email",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "email build --dir ../../packages/email/src/templates",
    "clean": "git clean -xdf .cache .react-email .turbo out node_modules",
    "dev": "email dev --dir ../../packages/email/src/templates --port 3005",
